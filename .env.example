# --- Required: server config ---

# Your school's myschoolapp subdomain (the part before .myschoolapp.com).
MSA_SUBDOMAIN=myschool

# Your numeric persona user id. Find it in DevTools > Network on any
# /api/user/profiletabs?showuserid=<this-number> request after you log in.
MSA_STUDENT_ID=0000000

# Optional: persona role. 2 = student, 3 = parent. Default 2.
# MSA_PERSONA_ID=2

# Optional: school year label as it appears in the app. Auto-derived from
# today's date if unset (e.g. "2025 - 2026" — note the spaces).
# MSA_SCHOOL_YEAR=2025 - 2026

# --- Cookie ---
# Three ways, checked in order:
#   1. MSA_COOKIE (raw header string)
#   2. MSA_COOKIES_FILE (path)
#   3. ~/.myschoolapp-mcp/cookie.txt (default), if it exists
#
# Easiest: run `myschoolapp-mcp-refresh` once to auto-generate cookie.txt.

# MSA_COOKIE=t=...; ASP.NET_SessionId=...; G_BB_=...
# MSA_COOKIES_FILE=/path/to/cookie.txt

# --- Required for `myschoolapp-mcp-refresh` (Playwright auto-login) ---
# Note: 2FA / MFA accounts are not supported by the auto-login flow.

SCHOOL_EMAIL=your-email@example.com
SCHOOL_PASS=your-password

# Optional: True = run Chromium headless; False = show window (useful for
# debugging or when login UI changes break the selectors).
HEADLESS=True

# Optional: per-step Playwright timeout in milliseconds.
TIMEOUT=30000

# Note: the refresh script also accepts SCHOOL_SUBDOMAIN as an alias for MSA_SUBDOMAIN.
